/* verification/synthesis/cells_sim.lib
 * Minimal Liberty file for gate-level simulation
 *
 * This provides basic timing for simulation purposes only.
 * For real ASIC synthesis, use your foundry's liberty file.
 *
 * Timing values are placeholder (1ns delay per gate).
 */

library(cells_sim) {
    technology (cmos);
    delay_model : table_lookup;

    time_unit : "1ns";
    voltage_unit : "1V";
    current_unit : "1mA";
    capacitive_load_unit (1, pf);

    /* Default timing */
    default_cell_leakage_power : 0;
    default_fanout_load : 1;
    default_inout_pin_cap : 0.01;
    default_input_pin_cap : 0.01;
    default_output_pin_cap : 0.01;

    /* ============================================= */
    /* Inverter                                      */
    /* ============================================= */
    cell(NOT) {
        area : 1;
        pin(A) { direction : input; }
        pin(Y) {
            direction : output;
            function : "A'";
            timing() {
                related_pin : "A";
                cell_rise(scalar) { values("0.1"); }
                cell_fall(scalar) { values("0.1"); }
                rise_transition(scalar) { values("0.05"); }
                fall_transition(scalar) { values("0.05"); }
            }
        }
    }

    /* ============================================= */
    /* Buffer                                        */
    /* ============================================= */
    cell(BUF) {
        area : 2;
        pin(A) { direction : input; }
        pin(Y) {
            direction : output;
            function : "A";
            timing() {
                related_pin : "A";
                cell_rise(scalar) { values("0.1"); }
                cell_fall(scalar) { values("0.1"); }
                rise_transition(scalar) { values("0.05"); }
                fall_transition(scalar) { values("0.05"); }
            }
        }
    }

    /* ============================================= */
    /* 2-input AND                                   */
    /* ============================================= */
    cell(AND2) {
        area : 2;
        pin(A) { direction : input; }
        pin(B) { direction : input; }
        pin(Y) {
            direction : output;
            function : "(A * B)";
            timing() {
                related_pin : "A B";
                cell_rise(scalar) { values("0.15"); }
                cell_fall(scalar) { values("0.15"); }
                rise_transition(scalar) { values("0.05"); }
                fall_transition(scalar) { values("0.05"); }
            }
        }
    }

    /* ============================================= */
    /* 2-input OR                                    */
    /* ============================================= */
    cell(OR2) {
        area : 2;
        pin(A) { direction : input; }
        pin(B) { direction : input; }
        pin(Y) {
            direction : output;
            function : "(A + B)";
            timing() {
                related_pin : "A B";
                cell_rise(scalar) { values("0.15"); }
                cell_fall(scalar) { values("0.15"); }
                rise_transition(scalar) { values("0.05"); }
                fall_transition(scalar) { values("0.05"); }
            }
        }
    }

    /* ============================================= */
    /* 2-input NAND                                  */
    /* ============================================= */
    cell(NAND2) {
        area : 2;
        pin(A) { direction : input; }
        pin(B) { direction : input; }
        pin(Y) {
            direction : output;
            function : "(A * B)'";
            timing() {
                related_pin : "A B";
                cell_rise(scalar) { values("0.12"); }
                cell_fall(scalar) { values("0.12"); }
                rise_transition(scalar) { values("0.05"); }
                fall_transition(scalar) { values("0.05"); }
            }
        }
    }

    /* ============================================= */
    /* 2-input NOR                                   */
    /* ============================================= */
    cell(NOR2) {
        area : 2;
        pin(A) { direction : input; }
        pin(B) { direction : input; }
        pin(Y) {
            direction : output;
            function : "(A + B)'";
            timing() {
                related_pin : "A B";
                cell_rise(scalar) { values("0.12"); }
                cell_fall(scalar) { values("0.12"); }
                rise_transition(scalar) { values("0.05"); }
                fall_transition(scalar) { values("0.05"); }
            }
        }
    }

    /* ============================================= */
    /* 2-input XOR                                   */
    /* ============================================= */
    cell(XOR2) {
        area : 3;
        pin(A) { direction : input; }
        pin(B) { direction : input; }
        pin(Y) {
            direction : output;
            function : "(A ^ B)";
            timing() {
                related_pin : "A B";
                cell_rise(scalar) { values("0.2"); }
                cell_fall(scalar) { values("0.2"); }
                rise_transition(scalar) { values("0.05"); }
                fall_transition(scalar) { values("0.05"); }
            }
        }
    }

    /* ============================================= */
    /* 2-input MUX                                   */
    /* ============================================= */
    cell(MUX2) {
        area : 4;
        pin(A) { direction : input; }
        pin(B) { direction : input; }
        pin(S) { direction : input; }
        pin(Y) {
            direction : output;
            function : "(S' * A) + (S * B)";
            timing() {
                related_pin : "A B S";
                cell_rise(scalar) { values("0.2"); }
                cell_fall(scalar) { values("0.2"); }
                rise_transition(scalar) { values("0.05"); }
                fall_transition(scalar) { values("0.05"); }
            }
        }
    }

    /* ============================================= */
    /* D Flip-Flop with async reset                  */
    /* ============================================= */
    cell(DFF_P) {
        area : 6;
        ff(IQ, IQN) {
            clocked_on : "CLK";
            next_state : "D";
        }
        pin(CLK) {
            direction : input;
            clock : true;
        }
        pin(D) { direction : input; }
        pin(Q) {
            direction : output;
            function : "IQ";
            timing() {
                related_pin : "CLK";
                timing_type : rising_edge;
                cell_rise(scalar) { values("0.3"); }
                cell_fall(scalar) { values("0.3"); }
                rise_transition(scalar) { values("0.1"); }
                fall_transition(scalar) { values("0.1"); }
            }
        }
    }

    /* ============================================= */
    /* D Flip-Flop with sync reset                   */
    /* ============================================= */
    cell(DFF_PR) {
        area : 8;
        ff(IQ, IQN) {
            clocked_on : "CLK";
            next_state : "D";
            clear : "R";
        }
        pin(CLK) {
            direction : input;
            clock : true;
        }
        pin(D) { direction : input; }
        pin(R) { direction : input; }
        pin(Q) {
            direction : output;
            function : "IQ";
            timing() {
                related_pin : "CLK";
                timing_type : rising_edge;
                cell_rise(scalar) { values("0.35"); }
                cell_fall(scalar) { values("0.35"); }
                rise_transition(scalar) { values("0.1"); }
                fall_transition(scalar) { values("0.1"); }
            }
        }
    }
}
