# verification/Makefile
# Cocotb + Verilator testbench for DLinear ASIC
# Stage 3: FST waveform support for Surfer analysis

# =============================================================================
# Configuration
# =============================================================================

# Native Verilator path (ARM64 Homebrew)
VERILATOR ?= /opt/homebrew/bin/verilator

# Verilog source (generated by Chisel - SystemVerilog)
VERILOG_SOURCES = $(shell pwd)/../hardware/generated/DLinearTop.sv

# Top module name
TOPLEVEL = DLinearTop

# Python test module (default: full test suite)
MODULE ?= tests.test_dlinear

# Simulator
SIM = verilator

# =============================================================================
# Verilator Flags
# =============================================================================

# FST tracing (smaller, faster than VCD)
EXTRA_ARGS += --trace-fst --trace-structs

# Suppress non-fatal warnings
EXTRA_ARGS += -Wno-fatal

# Optimization for ARM64
EXTRA_ARGS += -O3

# Allow top-level parameters
EXTRA_ARGS += -Wno-WIDTHEXPAND -Wno-WIDTHTRUNC

# =============================================================================
# Cocotb Configuration
# =============================================================================

# Enable FST waveform tracing by default
PLUSARGS ?= --trace

# Cocotb makefile (provides 'sim' target)
include $(shell cocotb-config --makefiles)/Makefile.sim

# =============================================================================
# Convenience Targets
# =============================================================================

# Generate Verilog from Chisel first
.PHONY: generate
generate:
	cd ../hardware && sbt "runMain dlinear.GenerateDLinear"

# Open waveform in Surfer
.PHONY: view
view:
	@if [ -f dump.fst ]; then \
		surfer dump.fst & \
	elif [ -f sim_build/dump.fst ]; then \
		surfer sim_build/dump.fst & \
	else \
		echo "No FST file found. Run 'make' first."; \
	fi

# Open waveform with Surfer state file (if exists)
.PHONY: waves
waves:
	@FST=$$(find . -name "*.fst" -type f | head -1); \
	if [ -n "$$FST" ]; then \
		if [ -f surfer_state.ron ]; then \
			surfer --state-file surfer_state.ron $$FST & \
		else \
			surfer $$FST & \
		fi \
	else \
		echo "No FST file found. Run 'make' first."; \
	fi

# Run full verification: generate, simulate, analyze
.PHONY: verify
verify: generate
	$(MAKE) -f $(firstword $(MAKEFILE_LIST))
	@echo ""
	@echo "========================================="
	@echo "Verification Complete"
	@echo "========================================="
	@echo "Results: results.xml"
	@echo "Waveform: $$(find . -name '*.fst' | head -1)"
	@echo ""
	@echo "Next: make view (open in Surfer)"

# Clean all build artifacts
.PHONY: cleanall
cleanall: clean
	rm -rf sim_build __pycache__ results.xml *.fst *.vcd

# Show Verilator version
.PHONY: version
version:
	$(VERILATOR) --version

# Run market data backtest
.PHONY: market
market:
	$(MAKE) MODULE=tests.test_market_data TOPLEVEL=$(TOPLEVEL)
	@echo ""
	@echo "Results saved to: outputs/asic_predictions.csv"
	@echo "Next: Open analysis/backtest_analysis.ipynb in Jupyter"

# Help
.PHONY: help
help:
	@echo "DLinear ASIC Verification Makefile"
	@echo ""
	@echo "Targets:"
	@echo "  make                        - Run full Cocotb test suite"
	@echo "  make market                 - Run market data backtest (Stage 4)"
	@echo "  make MODULE=tests.test_simple - Run simple sanity tests only"
	@echo "  make view                   - Open waveform in Surfer"
	@echo "  make waves                  - Open waveform with Surfer config"
	@echo "  make verify                 - Generate Verilog + Run tests"
	@echo "  make generate               - Regenerate Verilog from Chisel"
	@echo "  make cleanall               - Remove all build artifacts"
	@echo "  make version                - Show Verilator version"
